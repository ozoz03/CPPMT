{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build/debug.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "aarch64-debug",
      "displayName": "ARM64 Debug",
      "description": "Cross-compile debug build для Raspberry Pi / Radxa / Jetson через aarch64-linux-gnu toolchain.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/aarch64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Release with Debug Info",
      "description": "Release build з символами для GDB: оптимізації і мінімальний розмір бінарника, але з символами для налагодження.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/relwithdebinfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "relwithdebinfo-base",
      "displayName": "Release with Debug Info",
      "description": "Optimized build with debug symbols",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "description": "Зібрати debug preset після configure.",
      "configurePreset": "debug"
    },
    {
      "name": "aarch64-debug",
      "displayName": "Build ARM64 Debug",
      "description": "Зібрати ARM64 debug preset після cross-configure.",
      "configurePreset": "aarch64-debug"
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Build Release with Debug Info",
      "description": "Зібрати release with debug info preset після configure.",
      "configurePreset": "relwithdebinfo-base"
    }
  ]
}